# Dynatrace Extension build artifacts
*.zip
*.sig
extension/.build/
extension/dist/

# Signing certificates and keys (generated by VS Code plugin — keep private)
*.pem

# VS Code — ignore everything except the schema/task configs that matter for this project
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.vsix

# Python
.venv/
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/

# Environment variables and secrets (never commit!)
.env
.env.local
.env.*.local
*.token
api-token.txt
dt-token.txt

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor swap/backup files
*.swp
*.swo
*~
*.bak
*.backup

# Temporary files
tmp/
temp/
.tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Monaco
.monaco/

# Dynatrace Extensions build output and local config
dist/
config/
logs/
_JUNK/

# Local Claude skills and settings
skills-lock.json
.agents/
.claude/
